{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*).php",
      "destination": "/api/$1.php"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1.php"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
