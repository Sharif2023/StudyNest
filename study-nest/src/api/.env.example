# StudyNest API Environment
# Copy to .env and update values

# PostgreSQL (required)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studynest
DB_USER=postgres
DB_PASS=your_secure_password

# App (recommended)
APP_ENV=development
APP_URL=http://localhost:8000
APP_DEBUG=true

# Redis (for rate limiting/caching - optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (Phase 2)
JWT_SECRET=your_32_char_random_secret_key_here
JWT_EXPIRE=3600  # 1 hour
JWT_REFRESH_EXPIRE=604800  # 7 days

# Cloudinary (uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Production only
DB_POOL_SIZE=20
MAX_REQUEST_SIZE=10485760  # 10MB

