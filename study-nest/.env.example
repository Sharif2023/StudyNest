# StudyNest frontend environment
# Copy to .env.local and update values for your deployment.

VITE_API_URL=http://localhost/study-nest/api
VITE_API_BASE_URL=http://localhost/study-nest/api
VITE_WS_URL=ws://localhost:5001

# Cloudinary unsigned upload configuration used by browser uploads.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Optional TURN server configuration for WebRTC. Prefer short-lived credentials in production.
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
